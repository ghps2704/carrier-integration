{
    "compilerOptions": {
        "target": "ES2022",
        "moduleResolution": "NodeNext",
        "module": "NodeNext",
        "lib": [
            "ES2022"
        ],
        "sourceMap": true,
        "outDir": "dist",
        "strict": true,
        "resolveJsonModule": true,
        "removeComments": true,
        "noImplicitReturns": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "baseUrl": "."
    },
    "include": [
        "./src/**/*.ts",
        "./tests/**/*.ts",
        "./vitest.config.ts"
    ],
    "exclude": [
        "./node_modules/*",
        "dist"
    ]
}