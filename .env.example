# UPS API credentials — obtain from https://developer.ups.com
UPS_CLIENT_ID=your_client_id_here
UPS_CLIENT_SECRET=your_client_secret_here

# UPS API base URL
# Production:   https://onlinetools.ups.com
# CIE (testing): https://wwwcie.ups.com
UPS_BASE_URL=https://onlinetools.ups.com

# UPS OAuth 2.0 token endpoint
# Production:   https://onlinetools.ups.com/security/v1/oauth/token
# CIE (testing): https://wwwcie.ups.com/security/v1/oauth/token
UPS_AUTH_URL=https://wwwcie.ups.com/security/v1/oauth/token

# HTTP request timeout in milliseconds (default: 10000)
HTTP_TIMEOUT_MS=10000
